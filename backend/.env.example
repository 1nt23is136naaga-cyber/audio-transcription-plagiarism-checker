WINSTON_AI_API_KEY=your_winston_ai_api_key_here
#
# Copy this file to .env and fill in your actual API keys.
# NEVER commit the .env file — it is listed in .gitignore.
#
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

# ── Deepgram (voice transcription) ────────────────────────────────────────────
# Get your key at: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── OpenAI (optional — used only if deep GPT analysis is re-enabled) ──────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── PlagiarismCheck.org (plagiarism detection) ────────────────────────────────
# Get your token at: https://plagiarismcheck.org/api/
PLAGIARISM_API_TOKEN=your_plagiarism_api_token_here
